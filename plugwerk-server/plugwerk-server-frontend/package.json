{
  "name": "plugwerk-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run generate:api && vite",
    "build": "npm run generate:api && tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "generate:api": "openapi-generator-cli generate",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "license:check": "bash scripts/license-check.sh",
    "license:add": "bash scripts/license-check.sh --fix"
  },
  "dependencies": {
    "@codemirror/lang-html": "6.4.11",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@mui/material": "9.2.0",
    "@scalar/api-reference-react": "0.9.54",
    "@tanstack/react-query": "5.101.2",
    "@uiw/react-codemirror": "4.25.11",
    "axios": "1.18.1",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-dropzone": "15.0.0",
    "react-image-crop": "11.1.2",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.18.1",
    "rehype-sanitize": "6.0.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@openapitools/openapi-generator-cli": "2.39.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "dompurify": "^3.4.0",
    "follow-redirects": "^1.16.0",
    "postcss": "^8.5.10",
    "yaml": "^2.8.4"
  }
}
