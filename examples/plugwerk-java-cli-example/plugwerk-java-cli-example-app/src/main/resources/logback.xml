<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Default: only WARN and above from all libraries to keep CLI output clean.
         Set PLUGWERK_LOG_LEVEL=DEBUG to see PF4J plugin loading details. -->
    <variable name="LOG_LEVEL" value="${PLUGWERK_LOG_LEVEL:-WARN}"/>

    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss} [%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
